# Reguläre Anwendung
NODE_ENV=production
PORT=3000
SESSION_SECRET=mit-einem-kryptografisch-zufaelligen-wert-ersetzen

# Nur für eine zeitlich begrenzte Vorschau aktivieren.
# Nach der Entwicklung DEV_ACCESS_ENABLED=false setzen und optional
# middleware/developmentAccess.js sowie den markierten Block in server.js entfernen.
DEV_ACCESS_ENABLED=false
DEV_ACCESS_USERNAME_HASH=
DEV_ACCESS_PASSWORD_HASH=
DEV_ACCESS_REALM=SonoABCD Vorschau
DEV_ACCESS_CAPTCHA_TTL_MS=1800000

